{
  "name": "@clawguard/daemon",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty false",
    "clean": "tsc -b --clean",
    "test": "node --test \"dist/**/*.test.js\"",
    "dev": "node --enable-source-maps ./dist/index.js"
  },
  "dependencies": {
    "@clawguard/contracts": "workspace:*",
    "@clawguard/discovery": "workspace:*",
    "@clawguard/detonation": "workspace:*",
    "@clawguard/platform": "workspace:*",
    "@clawguard/reports": "workspace:*",
    "@clawguard/scanner": "workspace:*",
    "@clawguard/storage": "workspace:*"
  }
}
