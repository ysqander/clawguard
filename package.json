{
  "name": "clawguard",
  "version": "0.1.0",
  "description": "Local-first skill auditor for OpenClaw agents",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "clawguard": "./dist/index.js"
  },
  "files": [
    "dist",
    "sandbox",
    "README.md"
  ],
  "packageManager": "pnpm@10.19.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "pnpm -r --filter './packages/**' --filter './apps/**' run build",
    "typecheck": "pnpm -r --filter './packages/**' --filter './apps/**' run typecheck",
    "lint": "biome lint .",
    "format": "biome format . --write",
    "format:check": "biome format .",
    "test": "pnpm -r --if-present --filter './packages/**' --filter './apps/**' run test",
    "release:smoke": "pnpm build && node ./scripts/release-smoke.mjs",
    "release:build": "pnpm build && node ./scripts/release-build.mjs",
    "release:pack": "pnpm release:build && node ./scripts/release-pack.mjs",
    "release:smoke:install": "pnpm release:pack && node ./scripts/release-smoke-install.mjs",
    "release:check": "pnpm lint && pnpm format:check && pnpm typecheck && pnpm test && pnpm release:smoke && pnpm release:smoke:install",
    "clean": "pnpm -r --filter './packages/**' --filter './apps/**' run clean",
    "dev:cli": "pnpm --filter @clawguard/cli run dev",
    "dev:daemon": "pnpm --filter @clawguard/daemon run dev",
    "bench:static": "pnpm --filter @clawguard/scanner run bench:static",
    "bench:static:ci": "pnpm --filter @clawguard/scanner run bench:static:ci",
    "bench:detonation": "pnpm --filter @clawguard/detonation run bench:detonation",
    "bench:detonation:ci": "pnpm --filter @clawguard/detonation run bench:detonation:ci",
    "bench:detonation:preflight": "pnpm --filter @clawguard/detonation run bench:detonation:preflight"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/node": "^24.6.0",
    "esbuild": "^0.25.1",
    "typescript": "^5.9.3"
  }
}
